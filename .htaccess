# WT Fasteners — Apache Performance Config
# Render-blocking, cache, and compression optimizations

# ── Canonical Homepage Redirect ────────────────────────────────────────────────
# Redirect:
#   https://wtscrews.com/        -> https://wtscrews.com/pags/en/index.html
#   https://www.wtscrews.com/    -> https://wtscrews.com/pags/en/index.html
#   /index.html                  -> https://wtscrews.com/pags/en/index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
# Redirect root domain to English homepage
RewriteRule ^$ /pags/en/index.html [R=301,L]
  RewriteCond %{HTTP_HOST} ^(www\.)?wtscrews\.com$ [NC]
  RewriteCond %{REQUEST_URI} ^/?(index\.html)?$ [NC]
  RewriteRule ^ https://wtscrews.com/pags/en/index.html [R=301,L]
</IfModule>

# ── Enable Gzip / Deflate ──────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml text/xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# ── Efficient Cache Lifetimes ──────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # CSS / JS  — 1 year (bust with filename changes)
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType text/javascript           "access plus 1 year"

  # Images — 1 year
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/gif                 "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"

  # Fonts — 1 year
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType application/font-woff     "access plus 1 year"
  ExpiresByType application/font-woff2    "access plus 1 year"

  # JSON data — 1 hour (pages_*.json updated on publish)
  # Note: CGI endpoints returning JSON are overridden by FilesMatch "\.cgi$" no-store rule
  ExpiresByType application/json          "access plus 1 hour"

  # HTML — 10 minutes
  ExpiresByType text/html                 "access plus 10 minutes"
</IfModule>

# ── Cache-Control headers ──────────────────────────────────────────────────────
# Use "set" (not "append") so Cloudflare sees a single, authoritative header.
# max-age=31536000 tells Cloudflare to cache at the edge for 1 year.
<IfModule mod_headers.c>
  # CGI / API — never cache dynamic responses
  <FilesMatch "\.cgi$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>

  # Static assets — 1 year immutable (cache-bust via filename versioning)
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # CSS / JS — 1 year immutable
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # JSON data — 1 hour, must revalidate
  <FilesMatch "\.json$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>

  # HTML — 10 minutes, revalidate
  <FilesMatch "\.html?$">
    Header set Cache-Control "public, max-age=600, must-revalidate"
  </FilesMatch>

  # Security headers
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Keep-Alive ─────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>

# ── Vary: Accept-Encoding ──────────────────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|html|htm|xml|json)$">
    Header append Vary: Accept-Encoding
  </FilesMatch>
</IfModule>
